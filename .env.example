# ===========================================
# LLM Chess Coach - Environment Configuration
# ===========================================

# Environment (development|production)
ENVIRONMENT=development

# ===========================================
# Authentication & Security
# ===========================================

# Optional local-development API key bypass for `/v1/*`
# Do not rely on this in production.
API_KEY=your-local-dev-api-key

# Backend-issued bearer token signing secret (REQUIRED in production)
BACKEND_AUTH_SECRET=your-backend-auth-secret-here

# Sign in with Apple audience / iOS production bundle ID (REQUIRED in production)
APPLE_BUNDLE_ID=com.example.llmchesscoach

# App Store Connect numeric Apple app ID (REQUIRED in production for signed-data verification)
APPLE_APPLE_ID=1234567890

# PostgreSQL connection string for user entitlements and App Store purchases
# Local development can use SQLite, for example:
# DATABASE_URL=sqlite:////tmp/llm_chesscoach_entitlements.db
DATABASE_URL=postgresql://username:password@localhost:5432/llm_chesscoach

# App Store product ID for the 30-game consumable top-up
APPSTORE_PRODUCT_ID_30_GAMES=com.example.llmchesscoach.games30

# Comma-separated paths to Apple root certificate PEM files used by the App Store verifier
APPSTORE_ROOT_CERT_PATHS=/absolute/path/to/AppleRootCA-G3.pem,/absolute/path/to/AppleRootCA-G2.pem

# Optional App Store Server API credentials for future server-to-server lookups
APPSTORE_ISSUER_ID=your-app-store-issuer-id
APPSTORE_KEY_ID=your-app-store-key-id
APPSTORE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Trial / quota configuration
FREE_GAMES_PER_DAY=5
TRIAL_DAYS=14
APPSTORE_GAMES_PER_PURCHASE=30

# Optional test-only secrets to simulate Apple identity and StoreKit signed payloads locally
# APPLE_TEST_IDENTITY_SECRET=local-test-apple-secret
# APPSTORE_TEST_SHARED_SECRET=local-test-app-store-secret

# Allowed CORS origins (comma-separated, or * for all)
# In production, specify your domain(s)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ===========================================
# OpenAI API Configuration
# ===========================================

# OpenAI API Key (REQUIRED for LLM coaching features)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI Model (default: gpt-4)
OPENAI_MODEL=google/gemini-2.5-flash-lite

# Optional: Custom OpenAI API endpoint
OPENAI_API_ENDPOINT=https://openrouter.ai/api/v1

# ===========================================
# Stockfish Configuration
# ===========================================

# Path to Stockfish binary
# Ubuntu/Debian: /usr/games/stockfish
# Homebrew macOS: /opt/homebrew/bin/stockfish
STOCKFISH_PATH=stockfish

# Multi-PV analysis (number of principal variations)
MULTIPV=5

# Nodes per principal variation (higher = more accurate, slower)
NODES_PER_PV=1000000

# ===========================================
# Application Configuration
# ===========================================

# Logging level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO

# Number of Gunicorn workers (default: CPU count * 2 + 1)
# GUNICORN_WORKERS=4

# ===========================================
# Redis Configuration (Session Storage)
# ===========================================

# Redis URL for session storage (REQUIRED for multi-worker deployments)
# Local development: redis://localhost:6379/0
# Heroku: Automatically set by Heroku Redis add-on
# If not set, falls back to in-memory storage (single worker only)
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# Optional: Lichess Integration
# ===========================================

# Lichess API token for fetching games
# LICHESS_API_TOKEN=your-lichess-token-here
